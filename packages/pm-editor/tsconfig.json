{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@designer/core": ["../core/src"],
      "@designer/core/*": ["../core/src/*"],
      "@designer/pm-engine": ["../pm-engine/src"],
      "@designer/pm-engine/*": ["../pm-engine/src/*"],
      "@designer/assets/*": ["../assets/*"]
    },
    "composite": true,
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../core" },
    { "path": "../pm-engine" }
  ]
}
