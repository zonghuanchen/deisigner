{
  "name": "@designer/app",
  "version": "1.0.0",
  "description": "3D/2D display and UI layer for the 3D home designer",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node build.js",
    "build:types": "tsc --project tsconfig.build.json --emitDeclarationOnly",
    "prepublishOnly": "npm run build && npm run build:types",
    "publish:dist": "npm publish dist",
    "type-check": "tsc --project tsconfig.build.json --noEmit"
  },
  "peerDependencies": {
    "three": ">=0.170.0",
    "pixi.js": ">=8.6.0",
    "react": ">=18.3.0",
    "react-dom": ">=18.3.0",
    "@designer/core": "*"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.170.0",
    "pixi.js": "^8.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^3.0.2",
    "three": "^0.170.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.6.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
