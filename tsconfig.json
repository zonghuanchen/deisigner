{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@designer/core": ["packages/core/src"],
      "@designer/core/*": ["packages/core/src/*"],
      "@designer/app": ["packages/app/src"],
      "@designer/app/*": ["packages/app/src/*"],
      "@designer/editor": ["packages/editor/src"],
      "@designer/editor/*": ["packages/editor/src/*"]
    }
  },
  "references": [
    { "path": "packages/core" },
    { "path": "packages/app" },
    { "path": "packages/editor" }
  ],
  "include": [],
  "exclude": ["node_modules", "dist"]
}
